# Скопируйте файл окружения и заполните значения.

# Токен телеграм-бота
BOT_TOKEN='your_bot_token_here'

# Настройки основной постгрес-базы
DB_HOST="localhost"
DB_USER="db_user"
DB_PASSWORD="db_password"
DB_NAME="db_name"
DB_PORT=5432

# Настройки Юкассы
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY="your_secret_key_here"

# Идентификаторы администраторов: список чисел через запятую или массив
ADMIN_IDS=123456789

# Идентификатор группы логов
LOG_GROUP_ID=-100123456789

# Идентификатор канала для проверок подписки
CHANNEL_ID=-100987654321

# Подключение к базе таро-проекта
TAROT_DB_HOST="localhost"
TAROT_DB_USER="tarot_db_user"
TAROT_DB_PASSWORD="tarot_db_password"
TAROT_DB_NAME="tarot_db_name"
TAROT_DB_PORT=5432

# Прокси для сессии бота
# Поддерживаются два формата: полный и короткий
BOT_PROXY=
BOT_PROXY_SCHEME=http
