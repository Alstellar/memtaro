# .env.example
# Скопируйте этот файл в .env и заполните своими значениями

# Токен Telegram бота
BOT_TOKEN='ваш_токен_бота_здесь'

# Настройки базы данных PostgreSQL
DB_HOST="localhost"
DB_USER="имя_пользователя_бд"
DB_PASSWORD="пароль_пользователя_бд"
DB_NAME="имя_базы_данных"
DB_PORT=5432

# Настройки YooKassa
YOOKASSA_SHOP_ID=ваш_shop_id_здесь
YOOKASSA_SECRET_KEY="ваш_секретный_ключ_здесь"

# ID администраторов (через запятую, без пробелов)
ADMIN_IDS=123456789

# ID группы для логирования
LOG_GROUP_ID=-100123456789

# ID канала для проверки подписки
CHANNEL_ID=-100987654321