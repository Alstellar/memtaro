# .env.example
# Copy this file to .env and fill values.

# Telegram bot token
BOT_TOKEN='your_bot_token_here'

# PostgreSQL settings
DB_HOST="localhost"
DB_USER="db_user"
DB_PASSWORD="db_password"
DB_NAME="db_name"
DB_PORT=5432

# YooKassa settings
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY="your_secret_key_here"

# Admin IDs: CSV (123,456) or JSON array ([123,456])
ADMIN_IDS=123456789

# Logging group ID
LOG_GROUP_ID=-100123456789

# Channel ID for subscription checks
CHANNEL_ID=-100987654321
